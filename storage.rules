rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Default: deny all
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Bug report images: users can upload to their own path
    // Path pattern: bugReports/{userId}/{filename}
    match /bugReports/{userId}/{fileName} {
      // Only the owning user can upload
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024  // 10 MB max
        && request.resource.contentType.matches('image/.*');

      // Allow read for authenticated users (needed to display in admin tools)
      allow read: if request.auth != null;
    }
  }
}
