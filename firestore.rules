rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────────────────────
    // Default: deny all reads and writes
    // ──────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ──────────────────────────────────────────────
    // User data: only the owning user can read/write
    // ──────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Profile document
      match /profile/{docId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId
          && request.resource.data.keys().hasAll(['id', 'name', 'updatedAt'])
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0
          && request.resource.data.name.size() <= 100;
      }

      // Notes collection (EXAMPLE — remove when removing the Example module)
      match /notes/{noteId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null && request.auth.uid == userId
          && request.resource.data.keys().hasAll(['id', 'title', 'body', 'createdAt', 'updatedAt'])
          && request.resource.data.title is string
          && request.resource.data.body is string;
        allow update: if request.auth != null && request.auth.uid == userId
          && request.resource.data.title is string
          && request.resource.data.body is string;
        allow delete: if request.auth != null && request.auth.uid == userId;
      }

      // Add your own collections here following the same pattern:
      // match /yourCollection/{docId} {
      //   allow read: if request.auth != null && request.auth.uid == userId;
      //   allow write: if request.auth != null && request.auth.uid == userId;
      // }
    }

    // ──────────────────────────────────────────────
    // Bug reports: authenticated users can create, nobody can read via client
    // (Use Firebase Console or Admin SDK to review bug reports)
    // ──────────────────────────────────────────────
    match /bugReports/{reportId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['id', 'userId', 'description', 'createdAt'])
        && request.resource.data.description is string
        && request.resource.data.description.size() > 0
        && request.resource.data.description.size() <= 5000;
      allow read, update, delete: if false;
    }
  }
}
